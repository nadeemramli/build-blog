filters:
  and:
    - file.hasTag("competitor")
    - '!file.name.contains("Template")'
properties:
  file.name:
    displayName: Competitor
  positioning:
    displayName: Positioning
  products:
    displayName: # Products
  captured:
    displayName: Captured
views:
  - type: table
    name: Competitors
    order:
      - file.name
      - positioning
      - products
      - captured
    sort:
      - property: captured
        direction: DESC
